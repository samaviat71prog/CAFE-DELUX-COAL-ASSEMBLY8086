;==============================================================
; FW — file write: null-terminated string at DS:DX
;      Step 1: scan to find length (CX)
;      Step 2: one single INT 21H writes whole string at once
;==============================================================
FW PROC
PUSH AX
PUSH BX
PUSH CX
PUSH DX
PUSH SI
MOV SI, DX          ; SI = start of string, DX kept for write
MOV CX, 0           ; length counter
FW_SCAN:
MOV AL, [SI]        ; read byte
CMP AL, 0           ; null terminator?
JE FW_WRITE         ; yes - we know length now
INC SI
INC CX
JMP FW_SCAN
FW_WRITE:
CMP CX, 0           ; nothing to write?
JE FW_DONE
MOV BX, fileHandle  ; file handle
MOV AH, 40H         ; write to file
INT 21H             ; one call writes entire string
FW_DONE:
POP SI
POP DX
POP CX
POP BX
POP AX
RET
FW ENDP

;==============================================================
; FW_NUM — write AX as decimal digits to file
;==============================================================
FW_NUM PROC
PUSH AX
PUSH BX
PUSH CX
PUSH DX
MOV CX, 0
MOV BX, 10
FWN_D:
MOV DX, 0
DIV BX
PUSH DX
INC CX
CMP AX, 0
JNE FWN_D
FWN_W:
POP AX
ADD AL, 30H
MOV numByte, AL
PUSH CX
MOV BX, fileHandle
LEA DX, numByte
MOV CX, 1
MOV AH, 40H
INT 21H
POP CX
LOOP FWN_W
POP DX
POP CX
POP BX
POP AX
RET
FW_NUM ENDP

;==============================================================
; SCR_PRINT_NAME — print nameArr to screen
;==============================================================
SCR_PRINT_NAME PROC
MOV AH, 0
MOV AL, nameLen
CMP AL, 0
JE SPN_DONE
MOV CX, AX
LEA SI, nameArr
SPN_L:
MOV DL, [SI]
MOV AH, 02H
INT 21H
INC SI
LOOP SPN_L
SPN_DONE:
RET
SCR_PRINT_NAME ENDP

;==============================================================
; READ_NAME — reads chars into nameArr until Enter
;==============================================================
READ_NAME PROC
LEA DI, nameArr
MOV BL, 0
RNL:
MOV AH, 01H
INT 21H
CMP AL, 13       ; Enter
JE RN_DONE
CMP BL, 20       ; max 20 chars
JGE RNL
MOV [DI], AL
INC DI
INC BL
JMP RNL
RN_DONE:
MOV nameLen, BL
LEA DX, newline
MOV AH, 09H
INT 21H
RET
READ_NAME ENDP

;==============================================================
; GET_QTY — validated 1-9 input
;==============================================================
GET_QTY PROC
GQL:
LEA DX, qtyMsg
MOV AH, 09H
INT 21H
MOV AH, 01H
INT 21H
SUB AL, 30H
CMP AL, 1
JL GQ_BAD
CMP AL, 9
JG GQ_BAD
MOV tempQty, AL
RET
GQ_BAD:
LEA DX, invalidMsg
MOV AH, 09H
INT 21H
JMP GQL
GET_QTY ENDP

